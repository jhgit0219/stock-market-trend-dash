# Stock Market Trends — Environment Variables
# Copy this file to .env and fill in the values.
# The .env file is gitignored and must never be committed.

# ------------------------------------------------------------
# Alpha Vantage API
# ------------------------------------------------------------
# Optional. When unset, the backend serves mock data only.
# Obtain a free key at https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# ------------------------------------------------------------
# Backend CORS
# ------------------------------------------------------------
# Comma-separated list of origins allowed to call the API.
# In production, set this to your actual frontend origin.
# ALLOWED_ORIGINS=http://localhost:80,https://yourdomain.com

# ------------------------------------------------------------
# Cache TTLs (optional overrides — defaults shown)
# ------------------------------------------------------------
# HISTORY_CACHE_TTL_SECONDS=86400   # 24 hours
# LIST_CACHE_TTL_SECONDS=3600       # 1 hour
